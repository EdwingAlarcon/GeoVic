# ========================================
# Configuración de GeoVictoria
# ========================================
# 
# INSTRUCCIONES:
# 1. Copie este archivo y renómbrelo como ".env" (sin .example)
# 2. Complete sus credenciales de GeoVictoria
# 3. Guarde el archivo
# 4. Ejecute setup.bat para instalar el proyecto
#
# IMPORTANTE: Nunca comparta el archivo .env con sus credenciales
# ========================================

# Credenciales de acceso a GeoVictoria
GEOVICTORIA_USER=su_usuario_aqui
GEOVICTORIA_PASSWORD=su_contraseña_aqui

# ========================================
# Configuración Opcional
# ========================================
# Descomente y modifique si necesita personalizar

# Modo headless (navegador invisible)
# HEADLESS=true

# Timeouts (en milisegundos)
# IFRAME_TIMEOUT=30000
# BUTTON_TIMEOUT=5000
